rules_version = '2';

// Crafting a flexible, secure ecosystem of professional services.
service firebase.storage {
  match /b/{bucket}/o {
    
    // ── Bricoler Profile Assets ──────────────────────────────────────────────
    // Public read so anyone can view therapist/pro profiles.
    match /profile_photos/{userId}/{allPaths=**} {
      allow read: if true; 
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /verifications/{userId}/{allPaths=**} {
      allow read: if true; 
      allow write: if request.auth != null;
    }

    match /portfolio/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Order Attachments ──────────────────────────────────────────────────
    // Clients upload photos of what they need done.
    // Public read so images display in order-detail cards for both parties.
    match /orders/{orderId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null || orderId == 'anonymous';
    }

    // ── Bank Transfer Receipts ─────────────────────────────────────────────
    match /receipts/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null || userId == 'anonymous';
    }

    // ── Catch-all: deny everything else ────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
