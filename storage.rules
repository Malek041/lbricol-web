rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Avatar / Profile Photos ─────────────────────────────────────────────
    // Any authenticated user can upload their own avatar.
    // No content-type restriction — type is validated client-side before upload.
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 8 * 1024 * 1024;
    }

    // ── Portfolio Images ───────────────────────────────────────────────────
    // Bricolers upload portfolio images nested under their UID.
    match /portfolio/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 12 * 1024 * 1024;
    }

    // ── Verification Documents ─────────────────────────────────────────────
    // ID cards, licences, tour-guide authorisations (images or PDF).
    match /verifications/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 15 * 1024 * 1024;
    }

    // ── Order Attachments ──────────────────────────────────────────────────
    // Clients upload photos of what they need done.
    // Public read so images display in order-detail cards for both parties.
    match /orders/{orderId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 12 * 1024 * 1024;
    }

    // ── Bank Transfer Receipts ─────────────────────────────────────────────
    match /receipts/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 12 * 1024 * 1024;
    }

    // ── Catch-all: deny everything else ────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
