rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.role == 'admin';
    }

    // Only these fields can be changed by a client writing a review
    function isReviewUpdate() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasOnly(['reviews', 'totalRating', 'jobsCompleted', 'rating', 'completedJobs', 'stats']);
    }

    // ── 1. City Services (Publicly Readable) ───────────────────────────────
    match /city_services/{cityId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ── 2. Jobs (Marketplace matching) ─────────────────────────────────────
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() &&
        (resource.data.clientId == request.auth.uid || isAdmin());

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
      match /offers/{offerId} {
        allow read, write: if isSignedIn();
      }
    }

    // ── 3. Orders ──────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Owner (client or bricoler), or admin can read
      allow read: if isSignedIn() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.bricolerId == request.auth.uid ||
        isAdmin()
      );
      // Any signed-in user can create an order (client placing order)
      allow create: if isSignedIn();
      // Client or assigned bricoler can update (status changes, offers, etc.)
      allow update: if isSignedIn() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.bricolerId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // ── 4. Bricoler Profiles ───────────────────────────────────────────────
    match /bricolers/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isSignedIn() && (
        isOwner(userId) ||
        isAdmin() ||
        // Any signed-in client can submit a review
        isReviewUpdate()
      );
      allow delete: if isAdmin();
    }

    // ── 5. Client Profiles ─────────────────────────────────────────────────
    match /clients/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── 6. Users (Referrals, promo balances) ───────────────────────────────
    match /users/{userId} {
      allow read: if true;   // Public: allows referral code lookups
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isOwner(userId) ||
        // Allow incrementing referralBalance for a referrer
        request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly(['referralBalance'])
      );
      allow delete: if isAdmin();
    }

    // ── 7. Activity Logs ───────────────────────────────────────────────────
    match /activity/{activityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── 8. Bricoler Notifications ──────────────────────────────────────────
    match /bricoler_notifications/{notificationId} {
      allow read, update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.bricolerId ||
        request.auth.uid == resource.data.uid ||
        isAdmin()
      );
      allow create: if isSignedIn();
    }

    // ── 9. Drafts (local order drafts saved to Firestore) ──────────────────
    match /drafts/{draftId} {
      allow read, write: if isSignedIn() &&
        resource.data.clientId == request.auth.uid;
      allow create: if isSignedIn();
    }

    // ── 11. Client Notifications ──────────────────────────────────────────────
    match /client_notifications/{notificationId} {
      allow read, update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.clientId ||
        isAdmin()
      );
      allow create: if isSignedIn();
    }

    // ── 12. Collection Group: Messages (cross-collection reads) ────────────
    match /{path=**}/messages/{messageId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
