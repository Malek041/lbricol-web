rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Improved Admin check: checks both clients and bricolers collections
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/clients/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.get('role', '') == 'admin') ||
        (exists(/databases/$(database)/documents/bricolers/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/bricolers/$(request.auth.uid)).data.get('role', '') == 'admin') ||
        // Fallback for direct user collection if needed
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin')
      );
    }

    // Check if the current user is a registered bricoler
    function isBricoler() {
      return isSignedIn() && exists(/databases/$(database)/documents/bricolers/$(request.auth.uid));
    }

    // Only these fields can be changed by a client writing a review
    function isReviewUpdate() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasOnly(['reviews', 'totalRating', 'jobsCompleted', 'rating', 'completedJobs', 'stats', 'numReviews', 'score', 'totalRevenue', 'latestReviews']);
    }

    // ── 1. City Services & Metadata ──────────────────────────────────────
    match /city_services/{cityId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /city_monthly_stats/{statsId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    match /city_kpi_overview/{kpiId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── 2. Jobs & Orders (Marketplace matching) ──────────────────────────
    match /jobs/{jobId} {
      allow read: if true; // Public for marketplace visibility
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.clientId == request.auth.uid);

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
      match /offers/{offerId} {
        allow read, write: if isSignedIn();
      }
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && (
        !('clientId' in resource.data) || 
        resource.data.clientId == request.auth.uid || 
        resource.data.bricolerId == request.auth.uid
      ));
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (
        resource.data.clientId == request.auth.uid || 
        resource.data.bricolerId == request.auth.uid
      ));
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // ── 3. Profiles ────────────────────────────────────────────────────────
    match /bricolers/{userId} {
      allow read: if true;
      allow create: if isSignedIn(); // Allow creation if signed in, ownership verified by fields
      allow update: if isAdmin() || (isSignedIn() && (
        request.auth.uid == userId || 
        (resource != null && resource.data.get('uid', '') == request.auth.uid) ||
        isReviewUpdate()
      ));
      allow delete: if isAdmin() || (isSignedIn() && (
        !('uid' in resource.data) || 
        resource.data.uid == '' || 
        resource.data.uid == null ||
        resource.data.uid == request.auth.uid
      ));
    }

    match /clients/{userId} {
      allow read: if isAdmin() || isOwner(userId) || isBricoler();
      allow create: if isSignedIn();
      allow update: if isAdmin() || isOwner(userId) || (resource != null && resource.data.get('uid', '') == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin() || (resource != null && resource.data.get('uid', '') == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── 4. System & Notifications ────────────────────────────────────────
    match /city_index/{city}/providers/{bricolerId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == bricolerId || isAdmin());
    }

    match /accepted_jobs/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && (
        !('clientId' in resource.data) || 
        resource.data.clientId == request.auth.uid || 
        resource.data.bricolerId == request.auth.uid
      ));
      allow write: if isSignedIn(); // Basic write for now, specialized below if needed
    }

    match /activity/{activityId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /bricoler_notifications/{notificationId} {
      allow read: if isAdmin() || (isSignedIn() && (
        request.auth.uid == resource.data.get('bricolerId', '') || 
        request.auth.uid == resource.data.get('uid', '')
      ));
      allow write: if isSignedIn();
    }

    match /client_notifications/{notificationId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.get('clientId', ''));
      allow write: if isSignedIn();
    }

    match /drafts/{draftId} {
      allow read, write: if isAdmin() || (isSignedIn() && (
        resource == null ||
        resource.data.get('clientId', '') == request.auth.uid
      ));
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /commission_settlements/{settlementId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.bricolerId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /admin_notifications/{notificationId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── 5. Collection Group Rules ────────────────────────────────────────
    match /{path=**}/messages/{messageId} {
      allow read, write: if isSignedIn();
    }
    
    match /{path=**}/offers/{offerId} {
      allow read, write: if isSignedIn();
    }
  }
}
