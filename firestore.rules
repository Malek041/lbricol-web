rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Improved Admin check: checks both clients and bricolers collections
      return isSignedIn() && (
        exists(/databases/$(database)/documents/clients/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.role == 'admin'
      ) || (
        exists(/databases/$(database)/documents/bricolers/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/bricolers/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Only these fields can be changed by a client writing a review
    function isReviewUpdate() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasOnly(['reviews', 'totalRating', 'jobsCompleted', 'rating', 'completedJobs', 'stats']);
    }

    // ── 1. City Services (Publicly Readable) ───────────────────────────────
    match /city_services/{cityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── 2. Jobs (Marketplace matching) ─────────────────────────────────────
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
      match /offers/{offerId} {
        allow read, write: if isSignedIn();
      }
    }

    // ── 3. Orders ──────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Allow read if owner (client or bricoler), admin, or if it's an unassigned public order
      allow read: if isSignedIn() && (
        !('clientId' in resource.data) || // Safely handle newly created orders
        resource.data.clientId == request.auth.uid ||
        resource.data.bricolerId == request.auth.uid ||
        isAdmin()
      );
      
      allow create: if isSignedIn();
      
      // Allow update if and (owner or admin)
      allow update: if isSignedIn() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.bricolerId == request.auth.uid ||
        isAdmin()
      );
      
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // ── 4. Bricoler Profiles ───────────────────────────────────────────────
    match /bricolers/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isSignedIn() && (
        isOwner(userId) ||
        isAdmin() ||
        isReviewUpdate()
      );
      allow delete: if isAdmin();
    }

    // ── 5. Client Profiles ─────────────────────────────────────────────────
    match /clients/{userId} {
      allow read: if isOwner(userId) || isAdmin() || exists(/databases/$(database)/documents/bricolers/$(request.auth.uid));
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── 6. Users (Referrals, promo balances, etc.) ────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn(); 
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isOwner(userId) ||
        // Allow anyone to update another user's referralBalance (to reward a referrer)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['referralBalance']) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── 7. Activity Logs ───────────────────────────────────────────────────
    match /activity/{activityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── 8. Bricoler Notifications ──────────────────────────────────────────
    match /bricoler_notifications/{notificationId} {
      allow read, update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.get('bricolerId', '') ||
        request.auth.uid == resource.data.get('uid', '') ||
        isAdmin()
      );
      allow create: if isSignedIn();
    }

    // ── 9. Drafts (local order drafts) ─────────────────────────────────────
    match /drafts/{draftId} {
      allow read: if isSignedIn() && (resource.data.get('clientId', '') == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.get('clientId', '') == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.get('clientId', '') == request.auth.uid || isAdmin());
    }

    // ── 10. Reviews / Stats (if separate) ─────────────────────────────────
    // Handled in bricolers match if nested but good to have a backup if root collection exists
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── 11. Client Notifications ──────────────────────────────────────────
    match /client_notifications/{notificationId} {
      allow read, update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.get('clientId', '') ||
        isAdmin()
      );
      allow create: if isSignedIn();
    }

    // ── 12. Collection Group Rules ────────────────────────────────────────
    match /{path=**}/messages/{messageId} {
      allow read, write: if isSignedIn();
    }
    
    match /{path=**}/offers/{offerId} {
      allow read, write: if isSignedIn();
    }
  }
}
